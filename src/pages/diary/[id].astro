---
import Base from '../../layouts/Base.astro';
import diaryData from '../../data/diary.json';

export async function getStaticPaths() {
  return diaryData.diary
    .filter(d => !d.isDraft)
    .map(entry => ({
      params: { id: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;
---
<Base title={`${entry.title} · 不二`} description={entry.excerpt}>
  <a href="/diary" class="inline-flex items-center gap-1 text-emerald-500 dark:text-emerald-400 hover:text-emerald-600 dark:hover:text-pink-300 text-sm mb-6">
    ← 返回日记
  </a>
  <article class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-8">
    <div class="mb-6 pb-6 border-b border-gray-200 dark:border-gray-800">
      <span class="text-xs text-emerald-500 dark:text-emerald-400 mb-1 block">{entry.date} · {entry.category}</span>
      <h1 class="text-3xl font-bold mb-3">{entry.title}</h1>
      <div class="flex gap-2 flex-wrap">
        {entry.tags.map(tag => (
          <span class="px-2 py-0.5 bg-gray-100 dark:bg-gray-800 rounded text-xs text-gray-500 dark:text-gray-400">{tag}</span>
        ))}
        {entry.isMilestone && <span class="px-2 py-0.5 bg-yellow-100 dark:bg-yellow-900/30 rounded text-xs text-yellow-600 dark:text-yellow-400">🏆 里程碑</span>}
      </div>
    </div>
    <div id="diary-content" class="diary-content"></div>
  </article>
</Base>

<script define:vars={{ content: entry.content }}>
  document.addEventListener('DOMContentLoaded', function() {
    var el = document.getElementById('diary-content');
    if (el && content) {
      el.innerHTML = content;
    }
  });
</script>

<style>
  .diary-content {
    line-height: 1.8;
    color: var(--text-secondary, #374151);
  }
  .diary-content :global(h1) { font-size: 1.75rem; font-weight: 700; margin: 1.5rem 0 1rem; color: var(--text-primary, #111827); }
  .diary-content :global(h2) { font-size: 1.35rem; font-weight: 600; margin: 1.25rem 0 0.75rem; color: var(--text-primary, #111827); border-bottom: 1px solid #e5e7eb; padding-bottom: 0.3rem; }
  .diary-content :global(h3) { font-size: 1.1rem; font-weight: 600; margin: 1rem 0 0.5rem; color: var(--text-primary, #111827); }
  .diary-content :global(p) { margin: 0.6rem 0; }
  .diary-content :global(ul), .diary-content :global(ol) { margin: 0.5rem 0; padding-left: 1.5rem; }
  .diary-content :global(li) { margin: 0.25rem 0; }
  .diary-content :global(code) { background: #f3f4f6; padding: 0.1rem 0.35rem; border-radius: 0.25rem; font-size: 0.85em; }
  .diary-content :global(pre) { background: #1f2937; color: #e5e7eb; padding: 1rem; border-radius: 0.5rem; overflow-x: auto; margin: 1rem 0; }
  .diary-content :global(pre code) { background: none; padding: 0; color: inherit; }
  .diary-content :global(strong) { font-weight: 600; color: var(--text-primary, #111827); }
  :global(.dark) .diary-content { color: #cbd5e1; }
  :global(.dark) .diary-content :global(code) { background: #374151; }
  :global(.dark) .diary-content :global(pre) { background: #111827; }
</style>
