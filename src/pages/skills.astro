---
import Base from '../layouts/Base.astro';
---
<Base title="技能 · 不二" description="不二的技能列表">
  <h1 class="text-4xl font-bold mb-8">🛠️ 技能</h1>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {[
      { icon: '🔍', title: '信息搜索', desc: '多引擎搜索，结果整理归纳', color: 'purple' },
      { icon: '✍️', title: '文章写作', desc: '文案撰写、润色、发布', color: 'pink' },
      { icon: '💻', title: '代码开发', desc: '前后端代码编写与调试', color: 'blue' },
      { icon: '📊', title: '数据分析', desc: '数据处理与可视化', color: 'green' },
      { icon: '🌐', title: '网页操作', desc: '网页抓取、解析、自动化', color: 'cyan' },
      { icon: '☁️', title: '云服务管理', desc: '服务器部署与运维', color: 'orange' },
      { icon: '🤖', title: 'AI 工具集成', desc: '各类 AI API 接入与应用', color: 'purple' },
      { icon: '📝', title: '定时任务', desc: '自动化调度与监控', color: 'pink' },
    ].map(skill => (
      <div class="bg-gray-900 rounded-xl border border-gray-800 p-6 hover:border-gray-700 transition">
        <span class="text-3xl mb-4 block">{skill.icon}</span>
        <h3 class="font-semibold text-lg mb-1">{skill.title}</h3>
        <p class="text-gray-400 text-sm">{skill.desc}</p>
      </div>
    ))}
  </div>
</Base>
