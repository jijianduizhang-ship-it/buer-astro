---
import Base from '../../layouts/Base.astro';
import docsData from '../../data/documents.json';

export async function getStaticPaths() {
  return docsData.documents.map(doc => ({
    params: { id: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
---
<Base title={`${doc.title} · 不二`} description={doc.excerpt}>
  <a href="/documents" class="inline-flex items-center gap-1 text-zinc-500 dark:text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-300 text-sm mb-6">
    ← 返回文档
  </a>
  <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-8">
    <span class="text-xs text-zinc-500 dark:text-zinc-400 mb-2 block">{doc.category} · {doc.date}</span>
    <h1 class="text-3xl font-bold mb-4">{doc.title}</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-6">{doc.excerpt}</p>
    {doc.feishuUrl && (
      <a href={doc.feishuUrl} target="_blank" class="inline-flex items-center gap-2 px-4 py-2 bg-zinc-500 dark:bg-zinc-600 hover:bg-zinc-600 dark:hover:bg-zinc-500 rounded-lg text-sm transition text-white">
        📄 查看飞书原文
      </a>
    )}
    {doc.content && (
      <div class="prose-docs mt-6" set:html={doc.content} />
    )}
  </div>
</Base>

<style is:global>
  .prose-docs { line-height: 1.8; color: var(--text-secondary, #374151); }
  .prose-docs h1 { font-size: 1.75rem; font-weight: 700; margin: 1.5rem 0 1rem; color: var(--text-primary, #111827); }
  .prose-docs h2 { font-size: 1.35rem; font-weight: 600; margin: 1.25rem 0 0.75rem; color: var(--text-primary, #111827); border-bottom: 1px solid #e5e7eb; padding-bottom: 0.3rem; }
  .prose-docs h3 { font-size: 1.1rem; font-weight: 600; margin: 1rem 0 0.5rem; color: var(--text-primary, #111827); }
  .prose-docs p { margin: 0.6rem 0; }
  .prose-docs ul, .prose-docs ol { margin: 0.5rem 0; padding-left: 1.5rem; }
  .prose-docs li { margin: 0.25rem 0; }
  .prose-docs code { background: #f3f4f6; padding: 0.1rem 0.35rem; border-radius: 0.25rem; font-size: 0.85em; }
  .prose-docs pre { background: #1f2937; color: #e5e7eb; padding: 1rem; border-radius: 0.5rem; overflow-x: auto; margin: 1rem 0; }
  .prose-docs pre code { background: none; padding: 0; color: inherit; }
  .prose-docs table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.9rem; }
  .prose-docs th { background: #f3f4f6; padding: 0.5rem 0.75rem; text-align: left; font-weight: 600; border: 1px solid #e5e7eb; }
  .prose-docs td { padding: 0.4rem 0.75rem; border: 1px solid #e5e7eb; }
  .prose-docs blockquote { border-left: 3px solid #6366f1; padding-left: 1rem; color: #6b7280; margin: 1rem 0; }
  .prose-docs a { color: #6366f1; text-decoration: underline; }
  .prose-docs hr { border: none; border-top: 1px solid #e5e7eb; margin: 1.5rem 0; }
  .prose-docs strong { font-weight: 600; color: var(--text-primary, #111827); }
  :root.dark .prose-docs { color: #cbd5e1; }
  :root.dark .prose-docs code { background: #374151; }
  :root.dark .prose-docs pre { background: #111827; }
  :root.dark .prose-docs th { background: #1f2937; border-color: #374151; }
  :root.dark .prose-docs td { border-color: #374151; }
</style>
