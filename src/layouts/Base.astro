---
interface Props {
  title: string;
  description?: string;
}
const { title, description = '不二的数字基地，记录成长与折腾' } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>
    // Apply saved theme before render to avoid flash
    const saved = localStorage.getItem('theme');
    if (saved === 'light') {
      document.documentElement.classList.remove('dark');
      document.documentElement.classList.add('light');
    }
  </script>
  <style is:global>
    html.light { --bg-primary: #ffffff; --bg-secondary: #f9fafb; --bg-card: #ffffff; --border-color: #e5e7eb; --text-primary: #111827; --text-secondary: #374151; --text-muted: #6b7280; }
    html.dark, :not(html.light) { --bg-primary: #020617; --bg-secondary: #030f1e; --bg-card: #0f172a; --border-color: #1e293b; --text-primary: #f1f5f9; --text-secondary: #cbd5e1; --text-muted: #64748b; }
    html.light { background: #f9fafb; color: #111827; }
    html.dark { background: #020617; color: #f1f5f9; }
    html.light .nav-bg { background: #ffffff; border-color: #e5e7eb; }
    html.dark .nav-bg { background: #020617; border-color: #1e293b; }
    html.light .card-bg { background: #ffffff; border-color: #e5e7eb; }
    html.dark .card-bg { background: #0f172a; border-color: #1e293b; }
    html.light .card-hover:hover { border-color: #8b5cf6; }
    html.dark .card-hover:hover { border-color: #a855f7; }
    html.light .text-accent { color: #7c3aed; }
    html.dark .text-accent { color: #a855f7; }
    html.light .footer-bg { background: #f9fafb; border-color: #e5e7eb; }
    html.dark .footer-bg { background: #020617; border-color: #1e293b; }
  </style>
</head>
<body class="min-h-screen">
  <nav class="nav-bg border-b sticky top-0 z-50 backdrop-blur-md">
    <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="text-xl font-bold bg-gradient-to-r from-zinc-400 to-emerald-400 bg-clip-text text-transparent">
        不二
      </a>
      <div class="flex items-center gap-6 text-sm">
        <div class="flex gap-6">
          <a href="/documents" class="hover:text-zinc-400 transition">文档</a>
          <a href="/diary" class="hover:text-zinc-400 transition">日记</a>
          <a href="/about" class="hover:text-zinc-400 transition">关于</a>
          <a href="/skills" class="hover:text-zinc-400 transition">技能</a>
        </div>
        <button id="theme-toggle" class="p-2 rounded-lg border border-gray-300 dark:border-gray-600 hover:border-zinc-400 dark:hover:border-zinc-500 transition" title="切换主题" aria-label="切换深浅色模式">
          <svg id="sun-icon" class="w-4 h-4 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg id="moon-icon" class="w-4 h-4 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
      </div>
    </div>
  </nav>
  <main class="max-w-4xl mx-auto px-6 py-12">
    <slot />
  </main>
  <footer class="footer-bg border-t mt-20">
    <div class="max-w-4xl mx-auto px-6 py-8 text-center text-sm">
      不二 © 2026 · 记录成长与折腾
    </div>
  </footer>
  <script>
    const btn = document.getElementById('theme-toggle');
    const html = document.documentElement;

    function setTheme(dark) {
      if (dark) {
        html.classList.remove('light');
        html.classList.add('dark');
        document.getElementById('sun-icon').classList.add('hidden');
        document.getElementById('moon-icon').classList.remove('hidden');
        localStorage.setItem('theme', 'dark');
      } else {
        html.classList.remove('dark');
        html.classList.add('light');
        document.getElementById('sun-icon').classList.remove('hidden');
        document.getElementById('moon-icon').classList.add('hidden');
        localStorage.setItem('theme', 'light');
      }
    }

    // Init: check current state
    const isDark = html.classList.contains('dark');
    document.getElementById('sun-icon').classList.toggle('hidden', !isDark);
    document.getElementById('moon-icon').classList.toggle('hidden', isDark);

    btn.addEventListener('click', () => {
      const dark = html.classList.contains('dark');
      setTheme(!dark);
    });
  </script>
</body>
</html>
