---
interface Props {
  title: string;
  description?: string;
}
const { title, description = '不二的数字基地，记录成长与折腾' } = Astro.props;
const pathname = Astro.url.pathname;
const navItems = [
  { href: '/documents', label: '文档' },
  { href: '/diary', label: '日记' },
  { href: '/about', label: '关于' },
  { href: '/skills', label: '技能' },
];
const isActive = (href: string) => pathname === href || pathname.startsWith(href + '/');
---
<!DOCTYPE html>
<html lang="zh-CN" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>
    const saved = localStorage.getItem('theme');
    if (saved === 'light') {
      document.documentElement.classList.remove('dark');
      document.documentElement.classList.add('light');
    }
  </script>
  <style is:global>
    :root {
      --bg-primary: #ffffff; --bg-secondary: #f9fafb; --bg-card: #ffffff;
      --border-color: #e5e7eb; --text-primary: #111827; --text-secondary: #374151; --text-muted: #6b7280;
      --search-bg: #ffffff; --search-border: #d1d5db; --search-text: #111827; --search-placeholder: #9ca3af;
      --dropdown-bg: #ffffff; --dropdown-shadow: 0 10px 40px rgba(0,0,0,0.12);
    }
    :root.dark {
      --bg-primary: #020617; --bg-secondary: #030f1e; --bg-card: #0f172a;
      --border-color: #1e293b; --text-primary: #f1f5f9; --text-secondary: #cbd5e1; --text-muted: #64748b;
      --search-bg: #1e293b; --search-border: #334155; --search-text: #f1f5f9; --search-placeholder: #64748b;
      --dropdown-bg: #0f172a; --dropdown-shadow: 0 10px 40px rgba(0,0,0,0.5);
    }
    :root { background: #f9fafb; color: #111827; }
    :root.dark { background: #020617; color: #f1f5f9; }
    .light .nav-bg { background: rgba(255,255,255,0.9); border-color: #e5e7eb; }
    .dark .nav-bg { background: rgba(2,6,23,0.9); border-color: #1e293b; }
    .light .card-bg { background: #ffffff; border-color: #e5e7eb; }
    .dark .card-bg { background: #0f172a; border-color: #1e293b; }
    .light .card-hover:hover { border-color: #8b5cf6; }
    .dark .card-hover:hover { border-color: #a855f7; }
    .light .text-accent { color: #7c3aed; }
    .dark .text-accent { color: #a855f7; }
    .light .footer-bg { background: #f9fafb; border-color: #e5e7eb; }
    .dark .footer-bg { background: #020617; border-color: #1e293b; }
    .light .search-input:focus { border-color: #10b981; }
    .dark .search-input:focus { border-color: #34d399; }

    /* Search */
    .search-wrap { position: relative; }
    .search-popup {
      position: absolute;
      top: calc(100% + 8px);
      right: 0;
      z-index: 100;
      background: var(--dropdown-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      overflow: hidden;
      width: 300px;
      max-width: calc(100vw - 2rem);
    }
    .search-input {
      background: var(--search-bg);
      border: 1px solid var(--search-border);
      color: var(--search-text);
      border-radius: 0.75rem;
      padding: 0.5rem 1rem;
      font-size: 0.9rem;
      width: 100%;
      outline: none;
      box-shadow: var(--dropdown-shadow);
    }
    .search-input::placeholder { color: var(--search-placeholder); }
    .search-dropdown {
      width: 300px;
      max-width: calc(100vw - 2rem);
      background: var(--dropdown-bg);
      border: 1px solid var(--border-color);
      border-top: none;
      border-radius: 0 0 0.75rem 0.75rem;
      box-shadow: var(--dropdown-shadow);
      max-height: 400px;
      overflow-y: auto;
    }
    .search-item {
      display: block;
      padding: 0.75rem 1rem;
      border-bottom: 1px solid var(--border-color);
      text-decoration: none;
      transition: background 0.15s;
    }
    .search-item:last-child { border-bottom: none; }
    .search-item:hover { background: var(--bg-secondary); }
    .search-item-title { color: var(--text-primary); font-size: 0.875rem; font-weight: 500; }
    .search-item-meta { color: var(--text-muted); font-size: 0.75rem; margin-top: 2px; }
    .search-item-excerpt { color: var(--text-secondary); font-size: 0.8rem; margin-top: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .search-empty { padding: 1.5rem; text-align: center; color: var(--text-muted); font-size: 0.875rem; }
    .search-section-label { padding: 0.5rem 1rem 0.25rem; font-size: 0.7rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }

    /* Hamburger menu */
    .mobile-menu {
      position: fixed;
      inset: 0;
      background: var(--bg-primary);
      z-index: 200;
      display: flex;
      flex-direction: column;
      padding: 1rem;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s;
    }
    .mobile-menu.open { opacity: 1; pointer-events: all; }
    .mobile-menu-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; padding-top: 0.5rem; }
    .mobile-menu-links { display: flex; flex-direction: column; gap: 0.25rem; flex: 1; }
    .mobile-menu-links a {
      font-size: 1.25rem;
      padding: 0.75rem 1rem;
      border-radius: 0.75rem;
      color: var(--text-secondary);
      transition: background 0.15s, color 0.15s;
    }
    .mobile-menu-links a:hover, .mobile-menu-links a.active {
      background: var(--bg-secondary);
      color: var(--text-primary);
    }
    .mobile-menu-footer { display: flex; gap: 1rem; padding: 1rem 0; border-top: 1px solid var(--border-color); }
    .hamburger-btn { display: none; }
    @media (max-width: 640px) {
      .desktop-nav { display: none; }
      .hamburger-btn { display: flex; }
    }
  </style>
</head>
<body class="min-h-screen">
  <nav class="nav-bg border-b sticky top-0 z-50 backdrop-blur-md">
    <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between gap-4">
      <a href="/" class="text-xl font-bold bg-gradient-to-r from-zinc-400 to-emerald-400 bg-clip-text text-transparent shrink-0">
        不二
      </a>
      <nav class="desktop-nav hidden sm:flex items-center gap-5 text-sm">
        <a href="/documents" class="hover:text-zinc-400 transition text-zinc-500 dark:text-zinc-400">文档</a>
        <a href="/diary" class="hover:text-zinc-400 transition text-zinc-500 dark:text-zinc-400">日记</a>
        <a href="/about" class="hover:text-zinc-400 transition text-zinc-500 dark:text-zinc-400">关于</a>
        <a href="/skills" class="hover:text-zinc-400 transition text-zinc-500 dark:text-zinc-400">技能</a>
      </nav>
      <div class="flex items-center gap-2 shrink-0">
        <div class="search-wrap" id="search-container">
          <button id="search-trigger" class="p-2 rounded-lg border border-gray-300 dark:border-gray-600 hover:border-zinc-400 dark:hover:border-zinc-500 transition" title="搜索" aria-label="搜索">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </button>
          <div id="search-popup" class="search-popup" style="display:none;">
            <input type="search" id="search-input" class="search-input" placeholder="搜索文档和日记..." autocomplete="off" autofocus />
            <div id="search-dropdown" class="search-dropdown"></div>
          </div>
        </div>
        <button id="theme-toggle" class="p-2 rounded-lg border border-gray-300 dark:border-gray-600 hover:border-zinc-400 dark:hover:border-zinc-500 transition" title="切换主题" aria-label="切换深浅色模式">
          <svg id="sun-icon" class="w-4 h-4 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg id="moon-icon" class="w-4 h-4 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <button id="hamburger-btn" class="hamburger-btn p-2 rounded-lg border border-gray-300 dark:border-gray-600 hover:border-zinc-400 dark:hover:border-zinc-500 transition" aria-label="菜单">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="mobile-menu">
    <div class="mobile-menu-header">
      <a href="/" class="text-xl font-bold bg-gradient-to-r from-zinc-400 to-emerald-400 bg-clip-text text-transparent">不二</a>
      <button id="mobile-menu-close" class="p-2 rounded-lg border border-gray-300 dark:border-gray-600" aria-label="关闭">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="mobile-menu-links">
      <a href="/" class={isActive('/') ? 'active' : ''}>首页</a>
      {navItems.map(item => (
        <a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.label}</a>
      ))}
    </div>
    <div class="mobile-menu-footer">
      <button id="search-trigger-mobile" class="flex items-center gap-2 px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600 text-zinc-500 dark:text-zinc-400 text-sm flex-1">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        搜索...
      </button>
      <button id="theme-toggle-mobile" class="p-3 rounded-xl border border-gray-300 dark:border-gray-600" aria-label="切换主题">
        <svg id="sun-icon-mobile" class="w-5 h-5 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <svg id="moon-icon-mobile" class="w-5 h-5 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </div>
  </div>

  <main class="max-w-4xl mx-auto px-6 py-12">
    <slot />
  </main>

  <footer class="footer-bg border-t mt-20">
    <div class="max-w-4xl mx-auto px-6 py-8 text-center text-sm">
      不二 © 2026 · 记录成长与折腾
    </div>
  </footer>

  <script>
    const btn = document.getElementById('theme-toggle');
    const html = document.documentElement;

    function setTheme(dark) {
      if (dark) {
        html.classList.remove('light');
        html.classList.add('dark');
        document.getElementById('sun-icon').classList.add('hidden');
        document.getElementById('moon-icon').classList.remove('hidden');
        localStorage.setItem('theme', 'dark');
      } else {
        html.classList.remove('dark');
        html.classList.add('light');
        document.getElementById('sun-icon').classList.remove('hidden');
        document.getElementById('moon-icon').classList.add('hidden');
        localStorage.setItem('theme', 'light');
      }
    }

    const isDark = html.classList.contains('dark');
    document.getElementById('sun-icon').classList.toggle('hidden', !isDark);
    document.getElementById('moon-icon').classList.toggle('hidden', isDark);
    btn.addEventListener('click', () => setTheme(!html.classList.contains('dark')));

    // Search
    const searchContainer = document.getElementById('search-container');
    const searchTrigger = document.getElementById('search-trigger');
    const searchPopup = document.getElementById('search-popup');
    const searchInput = document.getElementById('search-input');
    const dropdown = document.getElementById('search-dropdown');
    let allData = { documents: [], diary: [] };
    let loaded = false;

    function openSearch() {
      const isD = html.classList.contains('dark');
      if (isD) {
        searchPopup.style.background = '#0f172a';
        searchPopup.style.borderColor = '#1e293b';
      } else {
        searchPopup.style.background = '#ffffff';
        searchPopup.style.borderColor = '#e5e7eb';
      }
      searchPopup.style.display = 'block';
      searchInput.focus();
    }

    function closeSearch() {
      searchPopup.style.display = 'none';
      if (searchInput) searchInput.value = '';
      if (dropdown) dropdown.innerHTML = '';
    }

    searchTrigger.addEventListener('click', () => {
      if (searchPopup.style.display === 'none' || !searchPopup.style.display) {
        openSearch();
      } else {
        closeSearch();
      }
    });

    async function loadSearchData() {
      if (loaded) return;
      try {
        const [docsRes, diaryRes] = await Promise.all([
          fetch('/data/documents.json'),
          fetch('/data/diary.json')
        ]);
        if (docsRes.ok) allData.documents = (await docsRes.json()).documents || [];
        if (diaryRes.ok) allData.diary = (await diaryRes.json()).diary || [];
        loaded = true;
      } catch(e) {}
    }

    function search(query) {
      if (!query.trim()) { dropdown.innerHTML = ''; return; }
      const q = query.toLowerCase();
      const docs = allData.documents.filter(d =>
        (d.title && d.title.toLowerCase().includes(q)) ||
        (d.excerpt && d.excerpt.toLowerCase().includes(q)) ||
        (d.category && d.category.toLowerCase().includes(q))
      ).slice(0, 5);
      const diary = allData.diary.filter(d =>
        (d.title && d.title.toLowerCase().includes(q)) ||
        (d.excerpt && d.excerpt.toLowerCase().includes(q)) ||
        (d.category && d.category.toLowerCase().includes(q))
      ).slice(0, 5);

      if (docs.length === 0 && diary.length === 0) {
        dropdown.innerHTML = '<div class="search-empty">没有找到匹配的内容</div>';
        return;
      }

      let h = '';
      if (docs.length > 0) {
        h += '<div class="search-section-label">📄 文档</div>';
        docs.forEach(d => {
          h += `<a class="search-item" href="/documents/${d.id}">
            <div class="search-item-title">${d.title}</div>
            <div class="search-item-meta">${d.category || ''} · ${d.date || ''}</div>
            ${d.excerpt ? `<div class="search-item-excerpt">${d.excerpt}</div>` : ''}
          </a>`;
        });
      }
      if (diary.length > 0) {
        h += '<div class="search-section-label">📔 日记</div>';
        diary.forEach(d => {
          h += `<a class="search-item" href="/diary/${d.id}">
            <div class="search-item-title">${d.title}</div>
            <div class="search-item-meta">${d.category || ''} · ${d.date || ''}</div>
            ${d.excerpt ? `<div class="search-item-excerpt">${d.excerpt}</div>` : ''}
          </a>`;
        });
      }
      dropdown.innerHTML = h;
    }

    searchInput.addEventListener('focus', () => { loadSearchData(); });
    searchInput.addEventListener('input', () => { loadSearchData(); search(searchInput.value); });
    document.addEventListener('click', e => {
      if (!e.target.closest('#search-container')) closeSearch();
    });
    searchInput.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeSearch();
    });

    // Mobile menu
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerBtn = document.getElementById('hamburger-btn');
    const mobileMenuClose = document.getElementById('mobile-menu-close');
    const searchTriggerMobile = document.getElementById('search-trigger-mobile');
    const themeToggleMobile = document.getElementById('theme-toggle-mobile');
    function openMobileMenu() { mobileMenu.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeMobileMenu() { mobileMenu.classList.remove('open'); document.body.style.overflow = ''; }
    hamburgerBtn.addEventListener('click', openMobileMenu);
    mobileMenuClose.addEventListener('click', closeMobileMenu);
    mobileMenu.addEventListener('click', e => { if (e.target === mobileMenu) closeMobileMenu(); });
    searchTriggerMobile.addEventListener('click', () => { closeMobileMenu(); openSearch(); });
    themeToggleMobile.addEventListener('click', () => { closeMobileMenu(); setTheme(!html.classList.contains('dark')); });
  </script>
</body>
</html>
